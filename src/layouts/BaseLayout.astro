---
import '../styles/tokens.css';
import '../styles/transitions.css';
import { ClientRouter } from 'astro:transitions';
import PatternBackground from '../components/brand/PatternBackground.astro';
import OrbitNav from '../components/layout/OrbitNav.astro';
import BlindsTransition from '../components/layout/BlindsTransition.astro';
import IntroOverlay from '../components/intro/IntroOverlay.astro';

interface Props {
  title?: string;
  description?: string;
  orbitTarget?: string;
  orbitMobileTarget?: string;
  orbitAnchorCorner?: 'top-right';
}

const {
  title = 'Marcos Koga (Koga Noodle)',
  description = "The personal corner of Marcos Koga, a Brazilian noodle dragon who codes, designs, and slurps down side projects for fun.",
  orbitTarget,
  orbitMobileTarget,
  orbitAnchorCorner,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://koga.gay');
const ogImage = new URL('/og-image.jpg', Astro.site ?? 'https://koga.gay');

const socials = [
  'https://twitter.com/koganoodle',
  'https://bsky.app/profile/koga.noodle.best',
  'https://www.youtube.com/@KogaNoodle',
  'https://twitch.tv/koganoodle',
  'https://t.me/koganoodle',
  'https://discordapp.com/users/170740606258249728',
  'https://vrchat.com/home/user/usr_3ac1b6e1-e410-4156-a75a-3e370dd6b814',
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Marcos Koga',
  alternateName: 'Koga Noodle',
  url: 'https://koga.gay',
  image: ogImage.href,
  jobTitle: 'Creative Technologist',
  nationality: { '@type': 'Country', name: 'Brazil' },
  sameAs: socials,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Marcos Koga" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0e0e12" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Marcos Koga (Koga Noodle)" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <ClientRouter />
    <script is:inline>
      // Show the intro splash on every FULL page load (reload / direct URL /
      // first visit), but NOT on in-app SPA navigations. `window` persists
      // across SPA swaps but resets on a full reload, so this flag fires once
      // per real page load.
      (function () {
        try {
          if (window.__kogaIntroScheduled) return;
          window.__kogaIntroScheduled = true;
          var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (!reduce) {
            document.documentElement.classList.add('intro-active');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <IntroOverlay />
    <PatternBackground transition:persist />
    <BlindsTransition />
    <OrbitNav
      target={orbitTarget}
      mobileTarget={orbitMobileTarget}
      anchorCorner={orbitAnchorCorner}
    />
    <main id="main" transition:name="content">
      <slot />
    </main>
  </body>
</html>
