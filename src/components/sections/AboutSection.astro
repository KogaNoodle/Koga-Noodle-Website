---
import SectionHeading from '../brand/SectionHeading.astro';
import Stamp from '../brand/Stamp.astro';
---

<section class="about container">
  <div class="about-stamp-wrap" aria-hidden="true">
    <Stamp size={280} />
  </div>
  <article class="about-card frosted">
    <SectionHeading text="Hello! I'm Marcos Koga!" class="about-title" />
    <div class="about-scroll">
      <div class="about-body">
        <p>
          Also known as Koga Noodle, your friendly Brazilian noodle dragon, and
          welcome to my corner of the internet!
        </p>
        <p>
          I'm a frontend developer with about two decades of experience under my
          belt, a variety streamer, and a creative explorer. I have always been
          driven by a need to express myself through different mediums, from
          drawing and dancing to my most recent passions: singing and 3D modeling
          in Blender.
        </p>
        <p>
          Streaming is one of my favorite forms of expression because I can blend
          my professional background with my content, building custom and
          interactive tools that allow my chat to engage with the stream in unique
          ways. Whether I'm diving into variety gaming, hanging out for a chill
          chat, or doing live development and experimentation, there's always
          something new happening here.
        </p>
        <p>
          When this noodle dragon leaves his cave, it's usually to travel with
          friends and visit them at big community events. I love hitting up
          conventions like FWA, Anthrocon, Midwest FurFest, and others.
        </p>
        <p class="rainbow-text">Thanks for stopping by!</p>
      </div>
    </div>
  </article>
</section>

<style>
  .about {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: var(--space-16);
  }

  @media (max-width: 767px) {
    .about {
      height: 100dvh;
      align-items: start;
    }
  }

  .about-stamp-wrap {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 280px;
    max-width: calc(100% - 5rem);
    opacity: 0.08;
    pointer-events: none;
    z-index: 0;
    animation: stamp-drift 24s ease-in-out infinite;
  }

  @keyframes stamp-drift {
    0%,
    100% {
      transform: translate(-50%, -50%) rotate(-4deg);
    }
    50% {
      transform: translate(-50%, -52%) rotate(4deg);
    }
  }

  .about-card {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: calc(48rem - 5rem);
    max-height: calc(100% - 5rem);
    padding: var(--space-12) var(--space-8);
    border-radius: var(--radius-lg);
    animation: card-in 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (max-width: 767px) {
    .about-card {
      max-height: 100%;
    }
  }

  .about-card :global(.about-title) {
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    .about-card :global(.about-title) {
      font-size: 1.75em;
    }
  }

  .about-scroll {
    flex: 1;
    min-height: 0;
    padding: 1rem 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.5) transparent;
    /* Gradient fade mask at top and bottom edges. */
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0,
      #000 2rem,
      #000 calc(100% - 2rem),
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      transparent 0,
      #000 2rem,
      #000 calc(100% - 2rem),
      transparent 100%
    );
  }

  @media (max-width: 767px) {
    .about-scroll {
      padding: 1rem 1rem 1rem 0;
    }
  }

  .about-scroll::-webkit-scrollbar {
    width: 8px;
  }

  .about-scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .about-scroll::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.5);
    border-radius: var(--radius-pill);
  }

  .about-scroll::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.7);
  }

  .about-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    color: var(--ink-muted);
    font-size: var(--font-size-base);
    line-height: 1.8;
  }

  .about-body p:last-child:not(.rainbow-text) {
    color: var(--ink);
    font-style: italic;
    opacity: 0.7;
  }

  @keyframes card-in {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .about-stamp-wrap {
      animation: none;
    }
    .about-card {
      animation: none;
    }
  }
</style>
