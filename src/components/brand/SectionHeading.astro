---
interface Props {
  text: string;
  font?: 'display' | 'art';
  as?: 'h1' | 'h2' | 'h3';
}

const { text, font = 'display', as: Tag = 'h1' }: Props = Astro.props;
---

<Tag class={`section-heading section-heading--${font}`}>{text}</Tag>

<style>
  .section-heading {
    margin: 0;
    font-size: 2.5rem;
    letter-spacing: 0.04em;
    line-height: 1.1;
    text-align: center;
    /* Gradient text + neon glow via drop-shadow (text-shadow is invisible on
       transparent-fill text, so filter is used instead). */
    background: var(--rainbow-gradient-loop);
    background-size: 200% 100%;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    filter: drop-shadow(0 0 22px rgba(253, 133, 216, 0.4));
  }

  .section-heading--art {
    font-family: var(--font-art);
  }

  @media (prefers-reduced-motion: no-preference) {
    .section-heading {
      animation: rainbow-shimmer 6s linear infinite;
    }
  }
</style>